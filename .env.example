# Vercel Blob 연결 시 Vercel 대시보드에서 자동으로 세팅됨
# 로컬 개발 시에만 아래 값을 .env.local 에 직접 채워넣으세요.
# (Vercel Storage 탭 > Blob > .env.local 다운로드 로 받을 수 있음)
BLOB_READ_WRITE_TOKEN=

# 이 API를 외부에서 호출할 때 검증용으로 쓰는 간단한 비밀키
# (Apps Script에서 호출할 때 헤더로 같이 보냄 — 아무나 이 API를 못 때리게 막는 최소한의 장치)
QR_API_SECRET=change_this_to_a_random_string
